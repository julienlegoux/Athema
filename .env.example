# Athema Environment Variables
# Copy this file to .env and fill in actual values.

# Server
ATHEMA_SERVER_HOST=0.0.0.0
ATHEMA_SERVER_PORT=8080

# Database
ATHEMA_DB_HOST=localhost
ATHEMA_DB_PORT=5432
ATHEMA_DB_DATABASE=athema
ATHEMA_DB_USERNAME=athema
ATHEMA_DB_PASSWORD=athema_dev
ATHEMA_DB_SSLMODE=disable

# LLM Provider
ATHEMA_LLM_PROVIDER=anthropic
ATHEMA_LLM_API_KEY=your-api-key-here
ATHEMA_LLM_MODEL=claude-sonnet-4-20250514

# Logging
ATHEMA_LOG_LEVEL=info
ATHEMA_LOG_FORMAT=json
